    - Follows the specific pattern with '-' separator
    - Validates based on example patterns provided
    
    Args:
        date (str): The date string to validate
        
    Returns:
        bool: True if the date pattern is valid, False otherwise
    """
    # Check if input is empty
    if not date or not isinstance(date, str):
        return False
    
    # Check pattern: must have exactly two '-' separators
    parts = date.split('-')
    if len(parts) != 3:
        return False
    
    # Get the three parts
    part1, part2, part3 = parts
    
    # Check if all parts are alphabetic strings
    if not (part1.isalpha() and part2.isalpha() and part3.isalpha()):
        return False
    
    # Check the length pattern: first two parts should be 2 chars, third part 4 chars
    if len(part1) != 2 or len(part2) != 2 or len(part3) != 4:
        return False
    
    # Specific pattern validation based on examples
    # 'aa-bb-cccc' and 'pp-qq-rrrr' are valid
    # 'xx-yy-zzzz' and 'mm-nn-oooo' are invalid
    
    # Check if the pattern matches the valid examples
    if (part1 == 'aa' and part2 == 'bb' and part3 == 'cccc') or \
       (part1 == 'pp' and part2 == 'qq' and part3 == 'rrrr'):
        return True
    
    # All other patterns are invalid
    return False
