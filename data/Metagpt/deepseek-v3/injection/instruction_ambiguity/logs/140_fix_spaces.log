ion": "Read the whole content of a file. Using absolute paths as the argument for specifying the file location.", "signature": "(self, path: str) -> metagpt.tools.libs.editor.FileBlock", "parameters": ""}, "scroll_down": {"type": "function", "description": "Moves the window down by 100 lines.", "signature": "(self) -> str", "parameters": ""}, "scroll_up": {"type": "function", "description": "Moves the window up by 100 lines.", "signature": "(self) -> str", "parameters": ""}, "search_dir": {"type": "function", "description": "Searches for search_term in all files in dir. If dir is not provided, searches in the current directory. ", "signature": "(self, search_term: str, dir_path: str = \'./\') -> str", "parameters": "Args: search_term: str: The term to search for. dir_path: str: The path to the directory to search."}, "search_file": {"type": "function", "description": "Searches for search_term in file. If file is not provided, searches in the current open file. ", "signature": "(self, search_term: str, file_path: Optional[str] = None) -> str", "parameters": "Args: search_term: str: The term to search for. file_path: str | None: The path to the file to search."}, "similarity_search": {"type": "async_function", "description": "Given a filename or a pathname, performs a similarity search for a given query across the specified file or path. This method searches the index repository for the provided query, classifying the specified files or paths. It performs a search on each cluster of files and handles non-indexed files separately, merging results from structured indices with any direct results from non-indexed files. This function call does not depend on other functions. ", "signature": "(query: str, path: Union[str, pathlib.Path]) -> List[str]", "parameters": "Args: query (str): The search query string to look for in the indexed files. path (Union[str, Path]): A pathname or filename to search within. Returns: List[str]: A list of results as strings, containing the text from the merged results and any direct results from non-indexed files. Example: >>> query = \\"The problem to be analyzed from the document\\" >>> file_or_path = \\"The pathname or filename you want to search within\\" >>> texts: List[str] = await Editor.similarity_search(query=query, path=file_or_path) >>> print(texts)"}, "write": {"type": "function", "description": "Write the whole content to a file. When used, make sure content arg contains the full content of the file.", "signature": "(self, path: str, content: str)", "parameters": ""}}, "tool_path": "metagpt/tools/libs/editor.py"}, "RoleZero": {"type": "class", "description": "A role who can think and act dynamically", "methods": {"ask_human": {"type": "async_function", "description": "Use this when you fail the current task or if you are unsure of the situation encountered. Your response should contain a brief summary of your situation, ended with a clear and concise question.", "signature": "(self, question: \'str\') -> \'str\'", "parameters": ""}, "reply_to_human": {"type": "async_function", "description": "Reply to human user with the content provided. Use this when you have a clear answer or solution to the user\'s question.", "signature": "(self, content: \'str\') -> \'str\'", "parameters": ""}}, "tool_path": "metagpt/roles/di/role_zero.py"}, "Terminal": {"type": "class", "description": "A tool for running terminal commands. Don\'t initialize a new instance of this class if one already exists. For commands that need to be executed within a Conda environment, it is recommended to use the `execute_in_conda_env` method.", "methods": {"run_command": {"type": "async_function", "description": "Executes a specified command in the terminal and streams the output back in real time. This command maintains state across executions, such as the current directory, allowing for sequential commands to be contextually aware. ", "signature": "(self, cmd: str, daemon=False) -> str", "parameters": "Args: cmd (str): The command to execute in the terminal. daemon (bool): If True, executes the command in an asynchronous task, allowing the main program to continue execution. Returns: str: The command\'s output or an empty string if `daemon` is True. Remember that when `daemon` is True, use the `get_stdout_output` method to get the output."}}, "tool_path": "metagpt/tools/libs/terminal.py"}, "Browser": {"type": "class", "description": "A tool for browsing the web. Don\'t initialize a new instance of this class if one already exists. Note: If you plan to use the browser to assist you in completing tasks, then using the browser should be a standalone task, executing actions each time based on the content seen on the webpage before proceeding to the next step. ## Example Issue: The details of the latest issue in the geekan/MetaGPT repository. Plan: Use a browser to view the details of the latest issue in the geekan/MetaGPT repository. Solution: Let\'s first open the issue page of the MetaGPT repository with the `Browser.goto` command >>> await browser.goto(\\"https://github.com/geekan/MetaGPT/issues\\") From the output webpage, we\'ve identified that the latest issue can be accessed by clicking on the element with ID \\"1141\\". >>> await browser.click(1141) Finally, we have found the webpage for the latest issue, we can close the tab and finish current task. >>> await browser.close_tab()", "methods": {"goto": {"type": "async_function", "description": "Navigate to a specific URL.", "signature": "(self, url: \'str\', timeout: \'float\' = 90000)", "parameters": ""}, "scroll": {"type": "async_function", "description": "Scroll the page up or down.", "signature": "(self, direction: \\"Literal[\'down\', \'up\']\\")", "parameters": ""}}, "tool_path": "metagpt/tools/libs/browser.py"}, "git_create_pull": {"type": "async_function", "description": "Creates a pull request on a Git repository. Use this tool in priority over Browser to create a pull request. ", "signature": "(base: \'str\', head: \'str\', 