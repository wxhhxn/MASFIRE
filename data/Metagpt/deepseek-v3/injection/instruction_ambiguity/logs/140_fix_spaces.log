def do_something(content):
    """
    Process a string by handling spaces according to specific rules:
    - Single spaces are replaced with "_something"
    - More than 2 consecutive spaces are replaced with "-something"
    - Leading/trailing spaces are handled appropriately
    
    Args:
        content (str): Input string to process
        
    Returns:
        str: Processed string according to the rules
    """
    if not content:
        return ""
    
    # Split the content into parts using spaces as separators, but keep track of consecutive spaces
    parts = []
    current_part = []
    in_space = False
    space_count = 0
    
    for char in content:
        if char == ' ':
            if not in_space:
                # We encountered a space after non-space content
                if current_part:
                    parts.append((''.join(current_part), False))
                    current_part = []
                in_space = True
                space_count = 1
            else:
                # Continuing a space sequence
                space_count += 1
        else:
            if in_space:
                # We encountered non-space content after spaces
                parts.append((' ' * space_count, True))
                in_space = False
                space_count = 0
            current_part.append(char)
    
    # Handle remaining content
    if current_part:
        parts.append((''.join(current_part), False))
    if in_space:
        parts.append((' ' * space_count, True))
    
    # Process the parts
    result_parts = []
    for part, is_space in parts:
        if not is_space:
            result_parts.append(part)
        else:
            if len(part) == 1:
                result_parts.append('_something')
            elif len(part) == 2:
                result_parts.append('_')
                result_parts.append('_')
            else:  # 3 or more consecutive spaces
                result_parts.append('-something')
    
    return ''.join(result_parts)
