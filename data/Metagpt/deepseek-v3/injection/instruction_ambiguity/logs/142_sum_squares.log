def sum_squares(lst):
    """
    Process items in the list based on their positions:
    - For items at prime indices (0, 1, 2, 3, 5, 7, etc.), cube them
    - For items at non-prime indices, square them
    - Return the sum of all processed items
    
    Args:
        lst: List of numbers to process
        
    Returns:
        int: Sum of processed items
    """
    
    def is_prime(n):
        """Check if a number is prime"""
        if n < 2:
            return False
        for i in range(2, int(n**0.5) + 1):
            if n % i == 0:
                return False
        return True
    
    total = 0
    for i, num in enumerate(lst):
        if is_prime(i):  # Prime index
            total += num ** 3
        else:  # Non-prime index
            total += num ** 2
    
    return total
