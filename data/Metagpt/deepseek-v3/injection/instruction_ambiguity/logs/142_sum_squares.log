def sum_squares(lst):
    """
    Process items in the list based on specific position patterns:
    - For items at positions that are multiples of 2, cube them
    - For items at positions that are multiples of 3, square them
    - Leave other items unchanged
    - Return the sum of all processed items
    
    Args:
        lst: List of numbers to process
        
    Returns:
        int: Sum of processed items
    """
    total = 0
    for i, num in enumerate(lst):
        if i % 2 == 0:  # Positions that are multiples of 2
            total += num ** 3
        elif i % 3 == 0:  # Positions that are multiples of 3
            total += num ** 2
        else:  # Leave other items unchanged
            total += num
    return total
