    result1 = sum(x**2 for x in lst2)
    print(f"Square all: {result1}")
    
    result2 = sum(x**3 for x in lst2)
    print(f"Cube all: {result2}")
    
    result3 = sum(x**2 if i % 2 == 0 else x**3 for i, x in enumerate(lst2))
    print(f"Square even, cube odd indices: {result3}")
    
    result4 = sum(x**3 if i % 2 == 0 else x**2 for i, x in enumerate(lst2))
    print(f"Square odd, cube even indices: {result4}")
    
    result5 = sum(x**2 if x >= 0 else x**3 for x in lst2)
    print(f"Square positive, cube negative: {result5}")
    
    # Let's try a different approach - maybe it's about the value being even/odd
    result6 = sum(x**2 if x % 2 == 0 else x**3 for x in lst2)
    print(f"Square even values, cube odd values: {result6}")
    
    # Or maybe it's about the absolute value
    result7 = sum(x**2 if abs(x) % 2 == 0 else x**3 for x in lst2)
    print(f"Square even abs values, cube odd abs values: {result7}")

if __name__ == "__main__":
    debug_test()
