def sum_squares(lst):
    """
    Process items in the list based on their positions:
    - For items at even indices (0-indexed), square them
    - For items at odd indices, cube them
    - Return the sum of all processed items
    
    Args:
        lst: List of numbers to process
        
    Returns:
        int: Sum of processed items
    """
    total = 0
    for i, num in enumerate(lst):
        if i % 2 == 0:  # Even index
            total += num ** 2
        else:  # Odd index
            total += num ** 3
    return total
