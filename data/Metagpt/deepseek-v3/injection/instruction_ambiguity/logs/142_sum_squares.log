def sum_squares(lst):
    """
    Process items in the list based on specific position-value patterns:
    - For items where value equals index, square them
    - For items where value equals index + 1, cube them  
    - Leave other items unchanged
    - Return the sum of all processed items
    
    Args:
        lst: List of numbers to process
        
    Returns:
        int: Sum of processed items
    """
    total = 0
    for i, num in enumerate(lst):
        if num == i:  # Value equals index
            total += num ** 2
        elif num == i + 1:  # Value equals index + 1
            total += num ** 3
        else:  # Leave other items unchanged
            total += num
    return total
