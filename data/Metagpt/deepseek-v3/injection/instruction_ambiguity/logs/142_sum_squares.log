from sum_squares import sum_squares

def test_sum_squares():
    """Test function for sum_squares implementation"""
    # Test case 1: [1,2,3] -> 6
    result1 = sum_squares([1, 2, 3])
    assert result1 == 6, f"Expected 6, got {result1}"
    
    # Test case 2: [] -> 0
    result2 = sum_squares([])
    assert result2 == 0, f"Expected 0, got {result2}"
    
    # Test case 3: [-1,-5,2,-1,-5] -> -126
    result3 = sum_squares([-1, -5, 2, -1, -5])
    assert result3 == -126, f"Expected -126, got {result3}"
    
    print("All test cases passed!")

if __name__ == "__main__":
    test_sum_squares()
