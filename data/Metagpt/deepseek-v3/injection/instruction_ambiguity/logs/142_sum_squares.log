def sum_squares(lst):
    """
    Process items in the list based on their values:
    - For positive numbers, square them
    - For negative numbers, cube them
    - Return the sum of all processed items
    
    Args:
        lst: List of numbers to process
        
    Returns:
        int: Sum of processed items
    """
    total = 0
    for num in lst:
        if num >= 0:  # Positive numbers
            total += num ** 2
        else:  # Negative numbers
            total += num ** 3
    return total
