def parts_in_content(content):
    """
    Process a string and return words excluding the shortest and longest ones.
    
    Args:
        content (str): Input string containing words separated by spaces
        
    Returns:
        str: Space-separated words excluding shortest and longest, in original order
        
    Constraints:
        * 1 <= len(content) <= 100
        * content contains only letters
    """
    # Validate input constraints
    if not (1 <= len(content) <= 100):
        raise ValueError("Content length must be between 1 and 100 characters")
    
    if not content.replace(" ", "").isalpha():
        raise ValueError("Content must contain only letters and spaces")
    
    words = content.split()
    if not words:
        return ""
    
    # Find min and max lengths
    lengths = [len(word) for word in words]
    min_len = min(lengths)
    max_len = max(lengths)
    
    # Return words that are not the shortest or longest
    result_words = []
    for word in words:
        word_len = len(word)
        if word_len != min_len and word_len != max_len:
            result_words.append(word)
    
    return ' '.join(result_words)
