ion": "Read the whole content of a file. Using absolute paths as the argument for specifying the file location.", "signature": "(self, path: str) -> metagpt.tools.libs.editor.FileBlock", "parameters": ""}, "scroll_down": {"type": "function", "description": "Moves the window down by 100 lines.", "signature": "(self) -> str", "parameters": ""}, "scroll_up": {"type": "function", "description": "Moves the window up by 100 lines.", "signature": "(self) -> str", "parameters": ""}, "search_dir": {"type": "function", "description": "Searches for search_term in all files in dir. If dir is not provided, searches in the current directory. ", "signature": "(self, search_term: str, dir_path: str = \'./\') -> str", "parameters": "Args: search_term: str: The term to search for. dir_path: str: The path to the directory to search."}, "search_file": {"type": "function", "description": "Searches for search_term in file. If file is not provided, searches in the current open file. ", "signature": "(self, search_term: str, file_path: Optional[str] = None) -> str", "parameters": "Args: search_term: str: The term to search for. file_path: str | None: The path to the file to search."}, "similarity_search": {"type": "async_function", "description": "Given a filename or a pathname, performs a similarity search for a given query across the specified file or path. This method searches the index repository for the provided query, classifying the specified files or paths. It performs a search on each cluster of files and handles non-indexed files separately, merging results from structured indices with any direct results from non-indexed files. This function call does not depend on other functions. ", "signature": "(query: str, path: Union[str, pathlib.Path]) -> List[str]", "parameters": "Args: query (str): The search query string to look for in the indexed files. path (Union[str, Path]): A pathname or filename to search within. Returns: List[str]: A list of results as strings, containing the tex