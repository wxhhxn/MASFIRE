def parts_in_content(content):
    """
    Process a string and return words with even lengths.
    
    Args:
        content (str): Input string containing words separated by spaces
        
    Returns:
        str: Space-separated words with even lengths, in original order
    """
    words = content.split()
    result_words = []
    
    for word in words:
        if len(word) % 2 == 0:
            result_words.append(word)
    
    return ' '.join(result_words)
