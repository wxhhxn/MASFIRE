def parts_in_content(content):
    """
    Process a string and return words with even lengths.
    
    Args:
        content (str): Input string containing words separated by spaces
        
    Returns:
        str: Space-separated words with even lengths, in original order
        
    Constraints:
        * 1 <= len(content) <= 100
        * content contains only letters
    """
    # Validate input constraints
    if not (1 <= len(content) <= 100):
        raise ValueError("Content length must be between 1 and 100 characters")
    
    if not content.replace(" ", "").isalpha():
        raise ValueError("Content must contain only letters and spaces")
    
    words = content.split()
    result_words = []
    
    for word in words:
        if len(word) % 2 == 0:
            result_words.append(word)
    
    return ' '.join(result_words)
