def parts_in_content(content):
    """
    Process a string and return words with even lengths.
    
    Args:
        content (str): Input string containing words separated by spaces
        
    Returns:
        str: Space-separated words with even lengths, in original order
        
    Examples:
        >>> parts_in_content("This is a test")
        'is'
        >>> parts_in_content("lets go for swimming")
        'go'
    """
    words = content.split()
    result_words = []
    
    for word in words:
        if len(word) % 2 == 0:
            result_words.append(word)
    
    return ' '.join(result_words)

# Test the function with provided examples
if __name__ == "__main__":
    # Test case 1
    result1 = parts_in_content("This is a test")
    print(f"Input: 'This is a test'")
    print(f"Expected: 'is'")
    print(f"Actual: '{result1}'")
    print(f"Match: {result1 == 'is'}")
    print()
    
    # Test case 2
    result2 = parts_in_content("lets go for swimming")
    print(f"Input: 'lets go for swimming'")
    print(f"Expected: 'go for'")
    print(f"Actual: '{result2}'")
    print(f"Match: {result2 == 'go for'}")
    print()
    
    # Additional test cases
    test_cases = [
        "hello world",
        "a bb ccc dddd",
        "test",
        "even odd",
        ""
    ]
    
    for test in test_cases:
