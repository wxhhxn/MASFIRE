import os

def mean_absolute_deviation(items):
    """
    Calculate the mean absolute deviation of a dataset.
    
    The mean absolute deviation is the average of the absolute differences
    between each data point and the mean of the dataset.
    
    Args:
        items: List of numerical values
        
    Returns:
        float: The mean absolute deviation
        
    Examples:
        >>> mean_absolute_deviation([1.0, 2.0, 3.0, 4.0])
        1.0
    """
    if not items:
        return 0.0
    
    # Calculate the mean
    mean = sum(items) / len(items)
    
    # Calculate the sum of absolute differences from the mean
    absolute_differences = [abs(x - mean) for x in items]
    
    # Return the average of absolute differences
    return sum(absolute_differences) / len(absolute_differences)

# Test the function with the provided example
test_result = mean_absolute_deviation([1.0, 2.0, 3.0, 4.0])
print(f"Test result: {test_result}")  # Should be 1.0

