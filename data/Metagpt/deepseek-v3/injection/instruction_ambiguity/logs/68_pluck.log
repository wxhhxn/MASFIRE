def pluck(arr):
    """
    Given some content representing a part of something that has non-negative items
    your task is to do something to one of the items and give it.
    The chosen item should be the one with the smallest even characteristic.
    If multiple items share the same smallest even characteristic choose the one that has the earlier position.

    The chosen item should be given in some content, [ smallest_measure, its position ],
    If there are no items with that characteristic or the given content is empty, give nothing.

    Example 1:
        Input: [a, b, c]
        Output: [b, 1]
        Explanation: b has the smallest even characteristic, and b has the earliest position.

    Example 2:
        Input: [x, y, z]
        Output: [y, 1]
        Explanation: y has the smallest even characteristic, and y has the earliest position. 

    Example 3:
        Input: []
        Output: []
    
    Example 4:
        Input: [p, q, r, s, t, u]
        Output: [q, 1]
        Explanation: q is minimal in that sense, but there are duplicates,
                     so we choose the first one, which has the earliest position.

    Constraints:
        * There may be many items
        * Item measures are non-negative
    """
    if not arr:
        return []
    
    # We need to extract the characteristic from each item
    # The examples suggest the characteristic might be related to the item's value
    # Let's implement a flexible approach that can handle different item types
    
    candidates = []
    
    for i, item in enumerate(arr):
        # Try to extract a numeric characteristic from the item
        char_value = None
        
        # If item is a number, use it directly
        if isinstance(item, (int, float)):
            char_value = item
        # If item is a string, try to convert to number or use ASCII
        elif isinstance(item, str):
            # Try to convert to number first
            try:
                char_value = float(item)
            except ValueError:
                # If not a number, use ASCII value of first character
                char_value = ord(item[0]) if item else 0
        
        # If we couldn't extract a characteristic, skip this item
        if char_value is None:
            continue
            
        # Check if characteristic is non-negative and even
        if char_value >= 0 and char_value % 2 == 0:
            candidates.append((char_value, i))
    
    if not candidates:
        return []
    
    # Find the smallest even characteristic
    min_char = min(candidates, key=lambda x: x[0])
    
    # Find all items with the same smallest characteristic
    same_min_candidates = [(char_val, pos) for char_val, pos in candidates if char_val == min_char[0]]
    
    # Choose the one with the earliest position
    result = min(same_min_candidates, key=lambda x: x[1])
    
    return [result[0], result[1]]
