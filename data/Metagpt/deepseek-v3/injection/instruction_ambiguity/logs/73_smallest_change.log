def some_action(items):
    """
    Given some content items, explore the minimum number of parts that
    need to be altered to make the content read similarly backwards and
    forwards. Such content is one that appears the same in reverse. Each
    alteration can change a part to any other part.

    For example:
    some_action([1,2,3,5,4,7,9,6]) == 4
    some_action([1, 2, 3, 4, 3, 2, 2]) == 1
    some_action([1, 2, 3, 2, 1]) == 0
    """
    n = len(items)
    if n <= 1:
        return 0
    
    # Create a DP table where dp[i][j] represents the minimum changes
    # needed to make the subarray from index i to j palindromic
    dp = [[0] * n for _ in range(n)]
    
    # Fill the table diagonally for all subarray lengths
    for length in range(2, n + 1):
        for i in range(n - length + 1):
            j = i + length - 1
            
            if items[i] == items[j]:
                # If endpoints are equal, no change needed for this pair
                # The changes needed are the same as for the inner subarray
                if i + 1 <= j - 1:
                    dp[i][j] = dp[i + 1][j - 1]
                else:
                    dp[i][j] = 0
            else:
                # If endpoints are different, we need at least one change
                # We can change either the left or right element to match the other
                # and take the minimum of these options plus 1 for the change
                if i + 1 <= j - 1:
                    dp[i][j] = min(dp[i + 1][j], dp[i][j - 1]) + 1
                else:
                    dp[i][j] = 1
    
    return dp[0][n - 1]
