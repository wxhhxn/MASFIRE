def some_function(values):
    """Map numeric values to labels based on sorted order.
    
    Args:
        values: List of numeric values
        
    Returns:
        List of labels corresponding to the sorted order of input values
    """
    # Sort the values and get their original indices
    sorted_indices = sorted(range(len(values)), key=lambda i: values[i])
    
    # Create labels based on the sorted order
    labels = [f'label{i+1}' for i in range(len(values))]
    
    # Reorder labels to match original input order
    result = [None] * len(values)
    for new_index, original_index in enumerate(sorted_indices):
        result[original_index] = labels[new_index]
    
    return result

# Test the function with the provided example
test_values = [4.0, 3, 1.7, 2, 3.5]
result = some_function(test_values)
print(f"Input: {test_values}")
print(f"Output: {result}")

