001|# Created: 2026-01-03
002|from decimal import Decimal, ROUND_HALF_DOWN
003|
004|
005|def closest_integer(value: str) -> int:
006|    """
007|    Return the closest integer to the numeric string `value`.
008|    Ties (.5) are rounded away from zero per provided implementation guidance.
009|    """
010|    s = value.strip()
011|    if 'e' in s.lower():
012|        dec = Decimal(str(float(s)))
013|    else:
014|        dec = Decimal(s)
015|    result = dec.quantize(Decimal('0'), rounding=ROUND_HALF_DOWN)
016|    return int(result)
