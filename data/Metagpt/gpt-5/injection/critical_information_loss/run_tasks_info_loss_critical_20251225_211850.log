def prime_length(string: str) -> bool:
    """
    Return True if the length of the string is a prime number, else False.
    Examples:
    prime_length('Hello') == True
    prime_length('abcdcba') == True
    prime_length('kittens') == True
    prime_length('orange') == False
    """
    n = len(string)
    if n < 2:
        return False
    if n % 2 == 0:
