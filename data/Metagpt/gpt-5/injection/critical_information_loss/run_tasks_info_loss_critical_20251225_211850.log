import math

def max_fill(grid, capacity):
    """
    Return the number of times buckets need to be lowered to empty all wells.
    Each row represents a single well, and each 1 in a row represents a single unit of water.
    """
    total = 0
    for row in grid:
        units = sum(row)
        if units:
            total += math.ceil(units / capacity)
    return total

