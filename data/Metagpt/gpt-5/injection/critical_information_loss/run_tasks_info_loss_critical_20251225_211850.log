def anti_shuffle(s: str) -> str:
    res = []
    i = 0
    n = len(s)
    while i < n:
        if s[i] == ' ':
            j = i
            while j < n and s[j] == ' ':
                j += 1
            res.append(s[i:j])
            i = j
        else:
            j = i
            while j < n and s[j] != ' ':
                j += 1
            res.append(''.join(sorted(s[i:j])))
            i = j
    return ''.join(res)

