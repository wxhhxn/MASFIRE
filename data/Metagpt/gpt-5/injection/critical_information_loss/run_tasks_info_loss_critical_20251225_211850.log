Write exactly this content to the file:

import math

def count_up_to(n):
    if n <= 2:
        return []
    def is_prime(x):
        if x < 2:
            return False
        if x % 2 == 0:
            return x == 2
        limit = math.isqrt(x)
        i = 3
        while i <= limit:
            if x % i == 0:
                return False
            i += 2
        return True
    return [i for i in range(2, n) if is_prime(i)]

