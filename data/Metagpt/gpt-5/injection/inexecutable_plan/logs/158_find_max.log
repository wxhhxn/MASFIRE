001|def right_angle_triangle(a, b, c):
002|    """
003|    Given the lengths of the three sides of a triangle. Return True if the three
004|    sides form a right-angled triangle, False otherwise.
005|    A right-angled triangle is a triangle in which one angle is right angle or
006|    90 degree.
007|    Example:
008|    right_angle_triangle(3, 4, 5) == True
009|    right_angle_triangle(1, 2, 3) == False
010|    """
011|    # Convert inputs to floats if possible; invalid inputs return False
012|    try:
013|        a = float(a)
014|        b = float(b)
015|        c = float(c)
016|    except (TypeError, ValueError):
017|        return False
018|
019|    # Sides must be positive
020|    if a <= 0 or b <= 0 or c <= 0:
021|        return False
022|
023|    # Triangle inequality must hold
024|    if a + b <= c or a + c <= b or b + c <= a:
025|        return False
026|
027|    # Check Pythagorean theorem with a small tolerance for floating-point values
028|    sides = sorted([a, b, c])
029|    epsilon = 1e-9
