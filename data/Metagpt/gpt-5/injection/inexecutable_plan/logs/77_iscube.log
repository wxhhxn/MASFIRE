# -*- coding: utf-8 -*-

def iscube(a):
    """
    Return True if integer a is a perfect cube of some integer, else False.
    Supports negative values and zero.
    Uses floating-point cube root with round-trip check as specified.
    """
    # Handle zero quickly
    if a == 0:
        return True
    # Compute a candidate k using floating-point rounding
    if a > 0:
        k = round(a ** (1/3))
    else:
        k = -round((-a) ** (1/3))
    return k * k * k == a

# Inline verification for CI (commented out by request)
