from typing import List, Any

def filter_integers(values: List[Any]) -> List[int]:
    """
    Filter given list of various runtime values only for integers.

    Returns only built-in Python int values.
    Excludes booleans (True/False), numpy integer types, and string representations of integers.

    >>> filter_integers(['a', 3.14, 5])
    [5]
    >>> filter_integers([1, 2, 3, 'abc', {}, []])
    [1, 2, 3]
    >>> filter_integers([True, False, 0, 1, 2])
    [0, 1, 2]
    >>> filter_integers(['5', 5, 5.0])
    [5]
    """
    return [v for v in values if type(v) is int]

