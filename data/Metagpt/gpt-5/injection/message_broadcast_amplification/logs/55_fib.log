str\', task_type: \'str\' = \'\')", "parameters": ""}, "finish_current_task": {"type": "function", "description": "Finish current task, set Task.is_finished=True, set current task to next task", "signature": "(self)", "parameters": ""}, "replace_task": {"type": "function", "description": "Replace an existing task (can be current task) based on task_id, and reset all tasks depending on it.", "signature": "(self, task_id: \'str\', new_dependent_task_ids: \'list[str]\', new_instruction: \'str\', new_assignee: \'str\')", "parameters": ""}, "reset_task": {"type": "function", "description": "Reset a task based on task_id, i.e. set Task.is_finished=False and request redo. This also resets all tasks depending on it. ", "signature": "(self, task_id: \'str\')", "parameters": "Args: task_id (str): The ID of the task to be reset."}}, "tool_path": "metagpt/schema.py"}, "DataAnalyst": {"type": "class", "description": "A role who can think and act dynamically", "methods": {"write_and_exec_code": {"type": "async_function", "description": "Write a code block for current task and execute it in an interactive notebook environment. ", "signature": "(self, instruction: \'str\' = \'\')", "parameters": "Args: instruction (optional, str): Further hints or notice other than the current task instruction, must be very concise and can be empty. Defaults to \\"\\"."}}, "tool_path": "metagpt/roles/di/data_analyst.py"}, "RoleZero": {"type": "class", "description": "A role who can think and act dynamically", "methods": {"ask_human": {"type": "async_function", "description": "Use this when you fail the current task or if you are unsure of the situation encountered. Your response should contain a brief summary of your situation, ended with a clear and concise question.", "signature": "(self, question: \'str\') -> \'str\'", "parameters": ""}, "reply_to_human": {"type": "async_function", "description": "Reply to human user with the content provided. Use this when you have a clear answer or solution to the user\'s question.", "signature": "(self, content: \'str\') -> \'str\'", "parameters": ""}}, "tool_path": "metagpt/roles/di/role_zero.py"}, "Browser": {"type": "class", "description": "A tool for browsing the web. Don\'t initialize a new instance of this class if one already exists. Note: If you plan to use the browser to assist you in completing tasks, then using the browser should be a standalone task, executing actions each time based on the content seen on the webpage before proceeding to the next step. ## Example Issue: The details of the latest issue in the geekan/MetaGPT repository. Plan: Use a browser to view the details of the latest issue in the geekan/MetaGPT repository. Solution: Let\'s first open the issue page of the MetaGPT repository with the `Browser.goto` command >>> await browser.goto(\\"https://github.com/geekan/MetaGPT/issues\\") From the output webpage, we\'ve identified that the latest issue can be accessed by clicking on the element with ID \\"1141\\". >>> await browser.click(1141) Finally, we have found the webpage for the latest issue, we can close the tab and finish current task. >>> await browser.close_tab()", "methods": {"click": {"type": "async_function", "description": "clicks on an element with a specific id on the webpage.", "signature": "(self, element_id: \'int\')", "parameters": ""}, "close_tab": {"type": "async_function", "description": "Close the currently active tab.", "signature": "(self)", "parameters": ""}, "go_back": {"type": "async_function", "description": "Navigate to the previously viewed page.", "signature": "(self)", "parameters": ""}, "go_forward": {"type": "async_function", "description": "Navigate to the next page (if a previous \'go_back\' action was performed).", "signature": "(self)", "parameters": ""}, "goto": {"type": "async_function", "description": "Navigate to a specific URL.", "signature": "(self, url: \'str\', timeout: \'float\' = 90000)", "parameters": ""}, "hover": {"type": "async_function", "description": "Hover over an element with id.", "signature": "(self, element_id: \'int\')", "parameters": ""}, "press": {"type": "async_function", "description": "Simulates the pressing of a key combination on the keyboard (e.g., Ctrl+v).", "signature": "(self, key_comb: \'str\')", "parameters": ""}, "scroll": {"type": "async_function", "description": "Scroll the page up or down.", "signature": "(self, direction: \\"Literal[\'down\', \'up\']\\")", "parameters": ""}, "tab_focus": {"type": "async_function", "description": "Open a new, empty browser tab.", "signature": "(self, page_number: \'int\')", "parameters": ""}, "type": {"type": "async_function", "description": "Use this to type the content into the field with id.", "signature": "(self, element_id: \'int\', content: \'str\', press_enter_after: \'bool\' = False)", "parameters": ""}}, "tool_path": "metagpt/tools/libs/browser.py"}, "Editor": {"type": "class", "description": "A tool for reading, understanding, writing, and editing files. Support local file including text-based files (txt, md, json, py, html, js, css, etc.), pdf, docx, excluding images, csv, excel, or online links", "methods": {"write": {"type": "function", "description": "Write the whole content to a file. When used, make sure content arg contains the full content of the file.", "signature": "(self, path: str, content: str)", "parameters": ""}, "read": {"type": "async_function", "description": "Read the whole content of a file. Using absolute paths as the argument for specifying the file location.", "signature": "(self, path: str) -> metagpt.tools.libs.editor.FileBlock", "parameters": ""}, "similarity_search": {"type": "async_function", "description": "staticmethod(function) -> method Convert a function to be a static method. A static method does not receive an implicit first argument. To declare a static method, use this idiom: class C: @staticmethod def f(arg1, arg2, ...): ... It can be called either on the class (e.g. C.f()) or on an instance (e.g. C()