001|def fib(n: int):
002|    """Return n-th Fibonacci number.
003|    >>> fib(10)
004|    55
005|    >>> fib(1)
006|    1
007|    >>> fib(8)
008|    21
009|    """
010|    if n < 0:
011|        raise ValueError('n must be non-negative')
012|    if n == 0:
013|        return 0
014|    a, b = 0, 1
015|    for _ in range(1, n):
016|        a, b = b, a + b
017|    return b
