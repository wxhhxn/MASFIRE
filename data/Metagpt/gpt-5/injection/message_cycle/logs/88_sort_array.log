import os
import ast
import importlib.util
import sys
from typing import Tuple

async def verify_sort_array_file(path: str) -> Tuple[bool, str]:
    report_lines = []

    # Step 1: Confirm file exists
    if not os.path.exists(path):
        return False, f"FAIL: File does not exist at path: {path}"
    report_lines.append(f"OK: File exists at {path}")

    # Step 2: Read file and ensure only imports and the function definition exist
    try:
        with open(path, "r", encoding="utf-8") as f:
            content = f.read()
    except Exception as e:
        return False, f"FAIL: Unable to read the file. Error: {e}"

    try:
        tree = ast.parse(content, filename=path)
    except SyntaxError as e:
        return False, f"FAIL: SyntaxError while parsing file: {e}"

    allowed_top_nodes = (ast.Import, ast.ImportFrom, ast.FunctionDef)
    extras = [node for node in tree.body if not isinstance(node, allowed_top_nodes)]
    if extras:
        kinds = [type(n).__name__ for n in extras]
        return False, f"FAIL: File contains extra top-level content not allowed: {kinds}"

    # Check explicit 'from typing import List' import presence (warn if missing)
    has_typing_list_import = False
    for node in tree.body:
        if isinstance(node, ast.ImportFrom) and node.module == "typing":
            if any(alias.name == "List" for alias in node.names):
                has_typing_list_import = True
                break
    if not has_typing_list_import:
        report_lines.append("WARN: 'from typing import List' not found explicitly. Spec expects this import.")

    # Ensure there is exactly one function 'sort_array' with a single parameter named 'array'
    func_nodes = [n for n in tree.body if isinstance(n, ast.FunctionDef) and n.name == "sort_array"]
    if not func_nodes:
        return False, "FAIL: Function 'sort_array' not found."
    if len(func_nodes) > 1:
        return False, "FAIL: Multiple 'sort_array' function definitions found."

    func = func_nodes[0]
    args = func.args.args
    if len(args) != 1 or args[0].arg != "array":
        return False, "FAIL: Function 'sort_array' must have exactly one parameter named 'array'."

    # Warn if missing type annotations
    if args[0].annotation is None or func.returns is None:
        report_lines.append("WARN: Missing type annotations for parameter or return type. Spec expects List[int] annotations.")

    report_lines.append("OK: Static checks passed (only imports and the function definition present).")

    # Step 3: Import the function dynamically and run quick checks
    module_name = "sort_array_module_verification"
    try:
        spec = importlib.util.spec_from_file_location(module_name, path)
        if spec is None or spec.loader is None:
            return False, "FAIL: Could not create import spec for the module."
        module = importlib.util.module_from_spec(spec)
        sys.modules[module_name] = module
        spec.loader.exec_module(module)
    except Exception as e:
        return False, f"FAIL: Error importing the module: {e}"

    if not hasattr(module, "sort_array"):
        return False, "FAIL: Imported module does not contain 'sort_array'."

    sort_array = getattr(module, "sort_array")

    # Functional tests
    try:
        assert sort_array([]) == []
        assert sort_array([5]) == [5]
        assert sort_array([2, 4, 3, 0, 1, 5]) == [0, 1, 2, 3, 4, 5]
        assert sort_array([2, 4, 3, 0, 1, 5, 6]) == [6, 5, 4, 3, 2, 1, 0]
        # Ensure input not mutated
        original = [2, 4, 3, 0, 1, 5]
        _ = sort_array(original)
        assert original == [2, 4, 3, 0, 1, 5], "Input array was mutated."
    except AssertionError as e:
        return False, f"FAIL: Functional test failed: {e}"
    except Exception as e:
        return False, f"FAIL: Error during functional tests: {e}"

    report_lines.append("OK: Functional tests passed.")
    return True, "\n".join(report_lines)

# Execute verification
