ption": "Hover over an element with id.", "signature": "(self, element_id: \'int\')", "parameters": ""}, "press": {"type": "async_function", "description": "Simulates the pressing of a key combination on the keyboard (e.g., Ctrl+v).", "signature": "(self, key_comb: \'str\')", "parameters": ""}, "scroll": {"type": "async_function", "description": "Scroll the page up or down.", "signature": "(self, direction: \\"Literal[\'down\', \'up\']\\")", "parameters": ""}, "tab_focus": {"type": "async_function", "description": "Open a new, empty browser tab.", "signature": "(self, page_number: \'int\')", "parameters": ""}, "type": {"type": "async_function", "description": "Use this to type the content into the field with id.", "signature": "(self, element_id: \'int\', content: \'str\', press_enter_after: \'bool\' = False)", "parameters": ""}}, "tool_path": "metagpt/tools/libs/browser.py"}, "Editor": {"type": "class", "description": "A tool for reading, understanding, writing, and editing files. Support local file including text-based files (txt, md, json, py, html, js, css, etc.), pdf, docx, excluding images, csv, excel, or online links", "methods": {"write": {"type": "function", "description": "Write the whole content to a file. When used, make sure content arg contains the full content of the file.", "signature": "(self, path: str, content: str)", "parameters": ""}, "read": {"type": "async_function", "description": "Read the whole content of a file. Using absolute paths as the argument for specifying the file location.", "signature": "(self, path: str) -> metagpt.tools.libs.editor.FileBlock", "parameters": ""}, "similarity_search": {"type": "async_function", "description": "staticmethod(function) -> method Convert a function to be a static method. A static method does not receive an implicit first argument. To declare a static method, use this idiom: class C: @staticmethod def f(arg1, arg2, ...): ... It can be called either on the class (e.g. C.f()) or on an instance (e.g. C()