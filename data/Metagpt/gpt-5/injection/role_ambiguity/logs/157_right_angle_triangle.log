x <= 0 or y <= 0 or z <= 0:\n        return False\n    if x + y <= z:\n        return False\n    return isclose(z * z, x * x + y * y, rel_tol=1e-9, abs_tol=1e-12)\n\nVerification commands:\n- Confirm file exists: ls -l /Users/user1/CODE/Tester/MetaGPT/humaneval_baseline/right_angle_triangle.py\n- Run quick tests:\n  python3 -c "import sys; sys.path.insert(0, \'/Users/user1/CODE/Tester/MetaGPT/humaneval_baseline\'); from right_angle_triangle import right_angle_triangle; assert right_angle_triangle(3,4,5) is True; assert right_angle_triangle(1,2,3) is False; print(\'OK\')"\nAcceptance criteria: file exists at the exact path; content matches exactly; test command prints \'OK\'. Priority: High. Due: Immediate. This task depends on tasks[\'1\']. [Assign to David]\n\n\n# Current Task\n{\'task_id\': \'2\', \'dependent_task_ids\': [\'1\'], \'instruction\': \'Write the provided function code to disk at \\\'/Users/user1/CODE/Tester/MetaGPT/humaneval_baseline/right_angle_triangle.py\\\' and verify it. Environment: macOS, Python >=3.8. Content: ONLY the import and function implementation. Exact file content to write:\\n\\nfrom math import isclose\\n\\ndef right_angle_triangle(a, b, c):\\n    try:\\n        sides = [float(a), float(b), float(c)]\\n    except (TypeError, ValueError):\\n        return False\\n    x, y, z = sorted(sides)\\n    if x <= 0 or y <= 0 or z <= 0:\\n        return False\\n    if x + y <= z:\\n        return False\\n    return isclose(z * z, x * x + y * y, rel_tol=1e-9, abs_tol=1e-12)\\n\\nVerification commands:\\n- Confirm file exists: ls -l /Users/user1/CODE/Tester/MetaGPT/humaneval_baseline/right_angle_triangle.py\\n- Run quick tests:\\n  python3 -c "import sys; sys.path.insert(0, \\\'/Users/user1/CODE/Tester/MetaGPT/humaneval_baseline\\\'); from right_angle_triangle import right_angle_triangle; assert right_angle_triangle(3,4,5) is True; assert right_angle_triangle(1,2,3) is False; print(\\\'OK\\\')"\\nAcceptance criteria: file exists at the exact path