001|import re
002|
003|
004|def anti_shuffle(s: str) -> str:
005|    """
006|    Return a version of the input string where each non-whitespace chunk
007|    has its characters sorted in ascending ASCII order, while preserving
008|    the original whitespace and their positions.
009|    """
010|    parts = re.split(r"(\s+)", s)
011|    return "".join(("".join(sorted(part)) if part and not part.isspace() else part) for part in parts)
