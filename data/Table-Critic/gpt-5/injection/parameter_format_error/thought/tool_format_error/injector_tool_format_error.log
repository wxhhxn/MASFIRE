on': 'Sort by position column to determine order'}}]}, {'category': 'Final Query', 'description': 'Generate the final answer based on the processed table', 'tools': [{'name': 'simple_query', 'function_name': 'simple_query', 'description': 'Answer the question based on the processed table, generating the final answer', 'use_case': 'Used after all table transformation operations are completed', 'required_params': [{'name': 'sample', 'type': 'dict', 'description': 'Sample data containing the question and processed table'}, {'name': 'table_info', 'type': 'dict', 'description': 'Information of the processed table'}, {'name': 'llm', 'type': 'LLM', 'description': 'Language model instance'}], 'optional_params': [{'name': 'debug', 'type': 'bool', 'default': False}, {'name': 'use_demo', 'type': 'bool', 'default': True, 'description': 'Whether to use demo prompts'}, {'name': 'llm_options', 'type': 'dict', 'description': 'Options for LLM generation'}], 'returns': 'Sample copy containing answer and confidence', 'note': 'This is the final step of the operation chain, not included in possible_next_operation_dict'}]}, {'category': 'Control Flow', 'description': 'Control the execution flow of the operation chain', 'tools': [{'name': '<END>', 'description': 'End-of-chain marker, indicating all necessary table transformations are completed', 'note': 'This is a special marker, not an actual function call'}]}]  

