  \"add_column\": [\"select_row\", \"select_column\", \"group_column\", \"sort_column\", \"<END>\"]  
  \"select_row\": [\"select_column\", \"group_column\", \"sort_column\", \"<END>\"]  
  \"select_column\": [\"group_column\", \"sort_column\", \"<END>\"]  
